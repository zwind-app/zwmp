# ZWMP runtime configuration
ZWMP_CONFIG=config/zwmp.config.json
ZWMP_DATA_DIR=data
ZWMP_CACHE_DB=data/cache/zwmp.sqlite3
ZWMP_RULE_OUTPUT_DIR=data/generated-rules

# AI provider. Leave unset or set ZWMP_AI_PROVIDER=none to use the v3 local validation finalizer.
# Use an OpenAI-compatible chat completions base URL, for example:
# ZWMP_AI_PROVIDER=https://api.openai.com/v1
ZWMP_AI_PROVIDER=none
ZWMP_AI_API_KEY=
ZWMP_AI_MODEL=gpt-4.1-mini

# Runtime limits
ZWMP_MAX_ITEMS=30
ZWMP_PROBE_ITEMS=3
ZWMP_REQUEST_TIMEOUT=12
ZWMP_MAX_HTML_BYTES=2000000
ZWMP_CHROME_HEADLESS_QUOTA=1
ZWMP_PREVIEW_DETAIL_LIMIT=30
