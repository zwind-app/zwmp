ZWMP_CONFIG=/etc/zwmp/zwmp.config.json
ZWMP_DATA_DIR=/opt/zwmp/data
ZWMP_CACHE_DB=/opt/zwmp/data/cache/zwmp.sqlite3
ZWMP_RULE_OUTPUT_DIR=/opt/zwmp/data/generated-rules
ZWMP_MAX_ITEMS=30
ZWMP_PROBE_ITEMS=3
ZWMP_REQUEST_TIMEOUT=20
ZWMP_MAX_HTML_BYTES=2000000
ZWMP_CHROME_HEADLESS_QUOTA=1

# Legacy AI fallback configuration. Prefer providers in zwmp.config.json for production.
ZWMP_AI_PROVIDER=none
ZWMP_AI_API_KEY=
ZWMP_AI_MODEL=gpt-4.1-mini
