ZWMP_CONFIG=/app/config/zwmp.config.json
ZWMP_DATA_DIR=/app/data
ZWMP_CACHE_DB=/app/data/cache/zwmp.sqlite3
ZWMP_RULE_OUTPUT_DIR=/app/data/generated-rules
ZWMP_MAX_ITEMS=30
ZWMP_PROBE_ITEMS=3
ZWMP_REQUEST_TIMEOUT=20
ZWMP_MAX_HTML_BYTES=2000000

# Legacy AI fallback configuration. Prefer providers in mounted config/zwmp.config.json.
ZWMP_AI_PROVIDER=none
ZWMP_AI_API_KEY=
ZWMP_AI_MODEL=gpt-4.1-mini
